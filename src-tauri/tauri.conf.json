{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Tabst",
	"version": "0.6.8",
	"identifier": "app.tabst.desktop",
	"build": {
		"beforeDevCommand": "pnpm dev:react",
		"beforeBuildCommand": "pnpm build:web",
		"devUrl": "http://127.0.0.1:7777",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Tabst",
				"width": 1400,
				"height": 900,
				"resizable": true
			}
		],
		"security": {
			"csp": {
				"default-src": "'self' customprotocol: asset:",
				"base-uri": "'self'",
				"object-src": "'none'",
				"frame-ancestors": "'none'",
				"script-src": "'self' 'wasm-unsafe-eval'",
				"style-src": "'self' 'unsafe-inline'",
				"connect-src": "'self' ipc: http://ipc.localhost",
				"img-src": "'self' asset: http://asset.localhost data: blob:",
				"font-src": "'self' asset: http://asset.localhost data: blob:",
				"media-src": "'self' asset: http://asset.localhost data: blob:",
				"worker-src": "'self' blob:"
			},
			"devCsp": {
				"default-src": "'self' customprotocol: asset: http://127.0.0.1:7777 ws://127.0.0.1:7777",
				"base-uri": "'self'",
				"object-src": "'none'",
				"frame-ancestors": "'none'",
				"script-src": "'self' 'unsafe-eval' 'wasm-unsafe-eval' http://127.0.0.1:7777",
				"style-src": "'self' 'unsafe-inline' http://127.0.0.1:7777",
				"connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:7777 ws://127.0.0.1:7777",
				"img-src": "'self' asset: http://asset.localhost data: blob: http://127.0.0.1:7777",
				"font-src": "'self' asset: http://asset.localhost data: blob: http://127.0.0.1:7777",
				"media-src": "'self' asset: http://asset.localhost data: blob: http://127.0.0.1:7777",
				"worker-src": "'self' blob: http://127.0.0.1:7777"
			}
		},
		"withGlobalTauri": true
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"externalBin": [
			"binaries/llama-server",
			"binaries/libggml-base.dylib",
			"binaries/libggml-base.0.dylib",
			"binaries/libggml-base.0.10.1.dylib",
			"binaries/libggml-blas.dylib",
			"binaries/libggml-blas.0.dylib",
			"binaries/libggml-blas.0.10.1.dylib",
			"binaries/libggml-cpu.dylib",
			"binaries/libggml-cpu.0.dylib",
			"binaries/libggml-cpu.0.10.1.dylib",
			"binaries/libggml-metal.dylib",
			"binaries/libggml-metal.0.dylib",
			"binaries/libggml-metal.0.10.1.dylib",
			"binaries/libggml-rpc.dylib",
			"binaries/libggml-rpc.0.dylib",
			"binaries/libggml-rpc.0.10.1.dylib",
			"binaries/libggml.dylib",
			"binaries/libggml.0.dylib",
			"binaries/libggml.0.10.1.dylib",
			"binaries/libllama-common.dylib",
			"binaries/libllama-common.0.dylib",
			"binaries/libllama-common.0.0.8989.dylib",
			"binaries/libllama.dylib",
			"binaries/libllama.0.dylib",
			"binaries/libllama.0.0.8989.dylib",
			"binaries/libmtmd.dylib",
			"binaries/libmtmd.0.dylib",
			"binaries/libmtmd.0.0.8989.dylib"
		],
		"resources": {
			"../README.md": "README.md",
			"../ROADMAP.md": "ROADMAP.md"
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"endpoints": [
				"https://github.com/LIUBINfighter/Tabst.app/releases/latest/download/latest-{{target}}-{{arch}}-{{bundle_type}}.json",
				"https://github.com/LIUBINfighter/Tabst.app/releases/latest/download/latest-{{target}}-{{arch}}.json"
			],
			"pubkey": "__UPDATER_PUBLIC_KEY__",
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
