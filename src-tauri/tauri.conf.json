{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Tabst",
	"version": "0.6.6-tauri-next",
	"identifier": "com.liubin.tabst",
	"build": {
		"beforeDevCommand": "pnpm dev:react",
		"beforeBuildCommand": "pnpm build:web",
		"devUrl": "http://127.0.0.1:7777",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Tabst",
				"width": 1400,
				"height": 900,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		},
		"withGlobalTauri": false
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"resources": {
			"../README.md": "README.md",
			"../ROADMAP.md": "ROADMAP.md"
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"endpoints": [
				"https://github.com/LIUBINfighter/Tabst.app/releases/latest/download/latest-{{target}}-{{bundle_type}}.json",
				"https://github.com/LIUBINfighter/Tabst.app/releases/latest/download/latest-{{target}}.json"
			],
			"pubkey": "__UPDATER_PUBLIC_KEY__",
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
